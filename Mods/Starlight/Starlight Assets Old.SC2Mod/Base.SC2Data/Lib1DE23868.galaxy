        UnitSetPropertyFixed(EventPlayerEffectUsedUnit(c_effectUnitSource), c_unitPropXP, IntToFixed(PlayerScoreValueGetAsInt(EventPlayerEffectUsedUnitOwner(c_effectPlayerSource), "BankDesertStrikeTerranVictories")));
    }
    else if (autoA2D887F4_val == "TrophyTotalKillsUpdateTrigger") {
        UnitSetPropertyFixed(EventPlayerEffectUsedUnit(c_effectUnitSource), c_unitPropXP, IntToFixed(PlayerScoreValueGetAsInt(EventPlayerEffectUsedUnitOwner(c_effectPlayerSource), "BankDesertStrikeTotalKills")));
    }
    else if (autoA2D887F4_val == "TrophyTotalLossesUpdateTrigger") {
        UnitSetPropertyFixed(EventPlayerEffectUsedUnit(c_effectUnitSource), c_unitPropXP, IntToFixed(PlayerScoreValueGetAsInt(EventPlayerEffectUsedUnitOwner(c_effectPlayerSource), "BankDesertStrikeTotalLosses")));
    }
    else if (autoA2D887F4_val == "TrophyZergGamesUpdateTrigger") {
        UnitSetPropertyFixed(EventPlayerEffectUsedUnit(c_effectUnitSource), c_unitPropXP, IntToFixed(PlayerScoreValueGetAsInt(EventPlayerEffectUsedUnitOwner(c_effectPlayerSource), "BankDesertStrikeZergGames")));
    }
    else if (autoA2D887F4_val == "TrophyZergVictoriesUpdateTrigger") {
        UnitSetPropertyFixed(EventPlayerEffectUsedUnit(c_effectUnitSource), c_unitPropXP, IntToFixed(PlayerScoreValueGetAsInt(EventPlayerEffectUsedUnitOwner(c_effectPlayerSource), "BankDesertStrikeZergVictories")));
    }
    else {
    }
    return true;
}

