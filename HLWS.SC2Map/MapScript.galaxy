//--------------------------------------------------------------------------------------------------
bool gt_debugTestPrint_Func (bool testConds, bool runActions) {
    string lv_attribute;
    // Conditions
    if (testConds) {
        if (!libDDE92A83_gv_sandboxMode) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    lv_attribute = StringSub(EventChatMessage(false), 7, StringLength(EventChatMessage(false)));

    UIDisplayMessage(PlayerGroupSingle(EventPlayer()), c_messageAreaChat, StringToText("'" + lv_attribute + "'"));
    UIDisplayMessage(PlayerGroupSingle(EventPlayer()), c_messageAreaChat, StringToText(GameAttributeGameValue(lv_attribute)));

    return true;
}

//--------------------------------------------------------------------------------------------------
void gt_debugTestPrint_Init () {
    gt_debugTestPrint = TriggerCreate("gt_debugTestPrint_Func");
    TriggerAddEventChatMessage(gt_debugTestPrint, c_playerAny, "-test ", false);
}

