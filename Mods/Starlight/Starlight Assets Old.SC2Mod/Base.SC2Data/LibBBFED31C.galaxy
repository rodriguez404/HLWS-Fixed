// Triggers
//--------------------------------------------------------------------------------------------------
// Trigger: End Game Donation Run
//--------------------------------------------------------------------------------------------------
bool libBBFED31C_gt_EndGameDonationRun_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    playergroup autoED880582_g;
    int autoED880582_var;

    // Actions
    if (!runActions) {
        return true;
    }

    if ((libBBFED31C_gv_showDonationDialogSetting == true)) {
        libBBFED31C_gf_DonationDialogForceOn();
    }

    autoED880582_g = PlayerGroupActive();
    autoED880582_var = -1;
    while (true) {
        autoED880582_var = PlayerGroupNextPlayer(autoED880582_g, autoED880582_var);
        if (autoED880582_var < 0) { break; }
        if ((PlayerGroupHasPlayer(libBBFED31C_gv_winnerGroupSetting, autoED880582_var) == true)) {
            libBBFED31C_gf_DonationDialogVictory(autoED880582_var);
        }
        else {
            libBBFED31C_gf_DonationDialogDefeat(autoED880582_var);
        }
    }
    return true;
}

