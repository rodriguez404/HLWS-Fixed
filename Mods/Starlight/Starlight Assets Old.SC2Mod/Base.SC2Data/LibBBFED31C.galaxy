//--------------------------------------------------------------------------------------------------
// Trigger: Open
//--------------------------------------------------------------------------------------------------
bool libBBFED31C_gt_Open_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Conditions
    if (testConds) {
        if (!((EventDialogControl() == libBBFED31C_gv_mainButton))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    if ((libBBFED31C_gv_donationDialog == c_invalidDialogId)) {
        libBBFED31C_gf_DonationDialogCreate();
    }

    if ((libBBFED31C_gv_donationDialogMoved == true)) {
        UISetFrameVisible(PlayerGroupSingle(EventPlayer()), c_syncFrameTypeInfoPanel, false);
    }

    libNtve_gf_SetDialogItemEditorValue(libBBFED31C_gv_donationDialogItem[4], libBBFED31C_gv_donationLinkA, PlayerGroupAll());
    if ((DialogIsVisible(libBBFED31C_gv_donationDialog, EventPlayer()) == true)) {
        DialogSetVisible(libBBFED31C_gv_donationDialog, PlayerGroupSingle(EventPlayer()), false);
    }
    else {
        DialogSetVisible(libBBFED31C_gv_donationDialog, PlayerGroupSingle(EventPlayer()), true);
    }
    return true;
}

