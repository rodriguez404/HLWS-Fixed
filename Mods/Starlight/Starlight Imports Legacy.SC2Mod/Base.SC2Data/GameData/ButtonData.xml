<?xml version="1.0" encoding="us-ascii"?>
<Catalog>
    <CButton default="1" id="Item">
        <TooltipFlags index="ShowHotkey" value="0"/>
        <TooltipFlags index="ShowLevel" value="0"/>
        <TooltipFlags index="ShowSupply" value="0"/>
        <TooltipFlags index="ShowTime" value="0"/>
        <TooltipFlags index="ShowCooldown" value="0"/>
        <TooltipFlags index="ShowRequirements" value="0"/>
        <TooltipFlags index="ShowAutocast" value="0"/>
        <EditorCategories value="Race:Item"/>
        <HidesForSimpleText value="0"/>
    </CButton>
    <CButton default="1" id="Place">
        <?token id="Targets" value="None"?>
        <?token id="Abil1" type="CButtonLink" value="Bogus"?>
        <?token id="Abil2" type="CButtonLink" value="Bogus"?>
        <?token id="Abil3" type="CButtonLink" value="Bogus"?>
        <?token id="Abil4" type="CButtonLink" value="Bogus"?>
        <?token id="Name" type="CUnitLink" value="Bogus"?>
        <!-- <?token id="Abil1" type="CButtonLink" value="Bogus"?> -->
        <!-- <?token id="Abil2" type="CButtonLink" value="Bogus"?> -->
        <!-- <?token id="Abil3" type="CButtonLink" value="Bogus"?> -->
        <!-- <?token id="Abil4" type="CButtonLink" value="Bogus"?> -->
        <!-- <?token id="Name" type="CUnitLink" value="Bogus"?> -->
        <Name value="Unit/Name/##Name##"/>
        <TooltipAppender Text="Button/Appender/NewLine"/>
        <TooltipAppender Text="Button/Appender/PlacePrefix"/>
        <TooltipAppender Text="Button/Appender/##Abil1##"/>
        <TooltipAppender Text="Button/Name/##Abil1##"/>
        <TooltipAppender Text="Button/Appender/##Abil2##"/>
        <TooltipAppender Text="Button/Name/##Abil2##"/>
        <TooltipAppender Text="Button/Appender/##Abil3##"/>
        <TooltipAppender Text="Button/Name/##Abil3##"/>
        <TooltipAppender Text="Button/Appender/##Abil4##"/>
        <TooltipAppender Text="Button/Name/##Abil4##"/>
        <TooltipAppender Text="Button/Appender/CanAttack##Targets##"/>
        <TooltipAppender Text="e_gameUIStringCanAttack##Targets##"/>
        <TooltipAppender Text="Button/Appender/##id##"/>
        <TooltipFlags index="ShowHotkey" value="0"/>
        <TooltipFlags index="ShowSupply" value="0"/>
        <TooltipFlags index="ShowTime" value="0"/>
        <TooltipFlags index="ShowAutocast" value="0"/>
        <EditorCategories value="Race:Place"/>
        <HidesForSimpleText value="0"/>
    </CButton>
    <CButton default="1" id="Upgrade">
        <?token id="Tooltip" type="CButtonLink" value="Bogus"?>
        <?token id="Upgrade" type="CUpgradeLink" value="Bogus"?>
        <!-- <?token id="Tooltip" type="CButtonLink" value="Bogus"?> -->
        <!-- <?token id="Upgrade" type="CUpgradeLink" value="Bogus"?> -->
        <Name value="Upgrade/Name/##Upgrade##"/>
        <Tooltip value="Button/Tooltip/##Tooltip##"/>
        <TooltipFlags index="ShowHotkey" value="0"/>
        <EditorCategories value="Race:Upgrade"/>
        <HidesForSimpleText value="0"/>
    </CButton>
</Catalog>
