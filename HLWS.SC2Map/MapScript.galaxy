//--------------------------------------------------------------------------------------------------
// Trigger: Give Experience (Sandbox)
//--------------------------------------------------------------------------------------------------
bool gt_sandboxXP_Func (bool testConds, bool runActions) {
    int lv_lvlValue;
    int[60] lv_lvlExpRequired;
    int init_i;
    int lv_xpSum;
    // Conditions
    if (testConds) {
        if (!libDDE92A83_gv_sandboxMode) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    // Taken From data - "Default Veterancy" xp values per lvl required
    for (init_i = 0; init_i < 60; init_i += 1) {
        lv_lvlExpRequired[init_i] = CatalogFieldValueGetAsInt(c_gameCatalogBehavior, "DefaultVeterancy", ("VeterancyLevelArray[" + IntToString(init_i) + "].MinVeterancyXP"), 0);
    }

    lv_lvlValue = StringToInt(StringSub(EventChatMessage(false), 6, StringLength(EventChatMessage(false))));

    if (lv_lvlValue >= 0 && lv_lvlValue < 60) {

        init_i = 0;
        for (init_i = 0; init_i < lv_lvlValue; init_i += 1) {
            lv_xpSum += lv_lvlExpRequired[init_i];
        }

        UnitGroupLoopBegin(UnitGroupSelected(EventPlayer()));
        for (; !UnitGroupLoopDone(); UnitGroupLoopStep()) {
            UnitSetPropertyFixed(UnitGroupLoopCurrent(), c_unitPropXP, 0.0);
            Wait(0.1, c_timeGame);
            UnitSetPropertyFixed(UnitGroupLoopCurrent(), c_unitPropXP, lv_xpSum);
        }
    }

    return true;
}

//--------------------------------------------------------------------------------------------------
void gt_sandboxXP_Init () {
    gt_sandboxXP = TriggerCreate("gt_sandboxXP_Func");
    TriggerAddEventChatMessage(gt_sandboxXP, c_playerAny, "-lvl ", false);
}

