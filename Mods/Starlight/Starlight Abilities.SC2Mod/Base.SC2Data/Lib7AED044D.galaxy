//--------------------------------------------------------------------------------------------------
bool lib7AED044D_gt_BuyItem_Func (bool testConds, bool runActions) {
    // Variable Declarations
    string lv_icon;

    // Automatic Variable Declarations
    string auto67DAB19C_val;

    // Variable Initialization
    lv_icon = (CatalogFieldValueGet(c_gameCatalogActor, StringSub(CatalogFieldValueGet(c_gameCatalogUnit, UnitGetType(EventUnitInventoryItem()), "Name", c_playerAny), 11, 99), "UnitIcon", c_playerAny));

    // Actions
    if (!runActions) {
        return true;
    }

    PlayerScoreValueSetFromInt(UnitGetOwner(EventUnit()), "ItemsPurchased", (PlayerScoreValueGetAsInt(UnitGetOwner(EventUnit()), "ItemsPurchased") + 1));
    SoundPlay(SoundLink("ReceiveGold", -1), PlayerGroupSingle(EventPlayer()), 100.0, 0.0);
    UnitSetOwner(EventUnitInventoryItem(), 0, true);
    auto67DAB19C_val = CatalogFieldValueGet(c_gameCatalogItem, UnitGetType(EventUnitInventoryItem()), "Class", 0);
    if (auto67DAB19C_val == "Upgradeable") {
        UIAlertUnit("HeroAlert", UnitGetOwner(EventUnit()), (StringExternal("Param/Value/lib_7AED044D_326265B4") + UnitTypeGetName(UnitGetType(EventUnitInventoryItem())) + StringExternal("Param/Value/lib_7AED044D_01534C0D")), lv_icon, EventUnit());
        PlayerScoreValueSetFromInt(UnitGetOwner(EventUnit()), "GoldSpentonEquipment", (PlayerScoreValueGetAsInt(UnitGetOwner(EventUnit()), "GoldSpentonEquipment") + UnitTypeGetCost(UnitGetType(EventUnitInventoryItem()), c_unitCostTerrazine)));
    }
    else if (auto67DAB19C_val == "Permanent") {
        PlayerScoreValueSetFromInt(UnitGetOwner(EventUnit()), "GoldSpentonEquipment", (PlayerScoreValueGetAsInt(UnitGetOwner(EventUnit()), "GoldSpentonEquipment") + UnitTypeGetCost(UnitGetType(EventUnitInventoryItem()), c_unitCostTerrazine)));
    }
    else if (auto67DAB19C_val == "Consumable") {
        PlayerScoreValueSetFromInt(UnitGetOwner(EventUnit()), "GoldSpentonConsumables", (PlayerScoreValueGetAsInt(UnitGetOwner(EventUnit()), "GoldSpentonConsumables") + UnitTypeGetCost(UnitGetType(EventUnitInventoryItem()), c_unitCostTerrazine)));
    }
    else if (auto67DAB19C_val == "ConsumableCrateLoot") {
        PlayerScoreValueSetFromInt(UnitGetOwner(EventUnit()), "GoldSpentonConsumables", (PlayerScoreValueGetAsInt(UnitGetOwner(EventUnit()), "GoldSpentonConsumables") + UnitTypeGetCost(UnitGetType(EventUnitInventoryItem()), c_unitCostTerrazine)));
    }
    else {
    }
    return true;
}

