// Triggers
//--------------------------------------------------------------------------------------------------
// Trigger: Worker Select Protoss
//--------------------------------------------------------------------------------------------------
bool lib1DE23868_gt_WorkerSelectProtoss_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Actions
    if (!runActions) {
        return true;
    }

    libDDE92A83_gf_SkinStore(EventPlayerEffectUsedUnit(c_effectUnitCaster));
    libNtve_gf_ReplaceUnit(EventPlayerEffectUsedUnit(c_effectUnitCaster), "WorkerProtoss", libNtve_ge_ReplaceUnitOptions_OldUnitsRelative);
    UnitSelect(libNtve_gf_LastReplacedUnit(), EventPlayerEffectUsedUnitOwner(c_effectPlayerCaster), true);
    UnitControlGroupAddUnit(EventPlayerEffectUsedUnitOwner(c_effectPlayerCaster), 1, libNtve_gf_LastReplacedUnit());
    libDDE92A83_gf_SkinRestore(libNtve_gf_LastReplacedUnit());
    lib038F51B7_gf_AbilityControlEnableDisable(true, PlayerGroupSingle(EventPlayerEffectUsedUnitOwner(c_effectPlayerCaster)));
    lib948F000A_gf_WorkerSelectRefresh(libNtve_gf_LastReplacedUnit());
    lib038F51B7_gf_AbilityControlSetRace(EventPlayerEffectUsedUnitOwner(c_effectPlayerCaster), 0);
    return true;
}

//--------------------------------------------------------------------------------------------------
void lib1DE23868_gt_WorkerSelectProtoss_Init () {
    lib1DE23868_gt_WorkerSelectProtoss = TriggerCreate("lib1DE23868_gt_WorkerSelectProtoss_Func");
    TriggerAddEventPlayerEffectUsed(lib1DE23868_gt_WorkerSelectProtoss, c_playerAny, "WorkerSelectProtossTrigger");
}

