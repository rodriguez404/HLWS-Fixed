        UnitSetPropertyFixed(EventPlayerEffectUsedUnit(c_effectUnitSource), c_unitPropXP, IntToFixed(PlayerScoreValueGetAsInt(EventPlayerEffectUsedUnitOwner(c_effectPlayerSource), "BankDesertStrikeProtossVictories")));
    }
