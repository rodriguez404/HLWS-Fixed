    }

    autoA2D887F4_val = EventPlayerEffectUsed();
    if (autoA2D887F4_val == "TrophyProtossGamesUpdateTrigger") {
        UnitSetPropertyFixed(EventPlayerEffectUsedUnit(c_effectUnitSource), c_unitPropXP, IntToFixed(PlayerScoreValueGetAsInt(EventPlayerEffectUsedUnitOwner(c_effectPlayerSource), "BankDesertStrikeProtossGames")));
    }
